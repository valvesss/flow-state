#!/usr/bin/env python3
"""flow-state entry point. Stdlib only, so it runs anywhere python3 does."""

import os
import sys

_here = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, os.path.join(os.path.dirname(_here), "src"))

from flowstate.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
